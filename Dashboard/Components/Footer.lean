import Dashboard.Common
import SSG.Html
import SSG.Tags

open Html

def footerComp (config : SConfig) : List Html :=
  let commitSha := config.custom.commitHash
  [
    .hr,
    .div [cls "footer"] [
      "Generated by commit ",
      .a s!"https://github.com/dwrensha/compfiles/commit/{commitSha}"
        [cls "external"] commitSha
    ]
  ]
